# Redis configuration file

# Port to listen on
port {{ redis_port }}

# Bind to all interfaces
bind {{ redis_bind }}

# Data directory
dir {{ redis_data_dir }}

# Log file
logfile {{ redis_log_dir }}/redis.log

# Enable cluster mode
cluster-enabled {{ redis_cluster_enabled }}

# Cluster config file (auto generated by Redis)
cluster-config-file nodes.conf

# Cluster node timeout in milliseconds
cluster-node-timeout {{ redis_cluster_node_timeout }}

# Enable AOF persistence
appendonly yes

# AOF file name
appendfilename "appendonly.aof"

# Protected mode off (needed for cluster)
protected-mode no

# Daemonize no (systemd manages this)
daemonize no
