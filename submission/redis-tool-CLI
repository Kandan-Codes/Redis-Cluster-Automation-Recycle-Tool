def upgrade(version):

    print(
        f"{YELLOW}Launching rolling upgrade to v{version}...{NC}"
    )

    log_action(
        "UPGRADE",
        "Rolling upgrade started"
    )

    subprocess.run(

        [
            "ansible-playbook",
            "playbooks/upgrade.yml",
            "-e",
            f"target_version={version}"
        ],

        cwd=ANSIBLE_DIR

    )

# --------------------------------------------------
# Verify
# --------------------------------------------------

def verify():

    print(
        f"{YELLOW}Running full verification...{NC}"
    )

    result = subprocess.run(
        [
            "ansible-playbook",
            "playbooks/verify_full.yml"
        ],
        cwd=ANSIBLE_DIR,
        capture_output=True,
        text=True
    )

    output = result.stdout

    data_integrity = "FAIL"
    version = "unknown"
    cluster_state = "fail"
    slots_ok = "0"
    master_count = 0
    replica_count = 0
    replication_up = 0

    for line in output.splitlines():

        line = line.strip()

        if line.startswith("DATA_INTEGRITY="):
            data_integrity = line.split("=", 1)[1]

        elif line.startswith("VERSION="):
            version = line.split("=", 1)[1]

        elif line.startswith("CLUSTER_STATE="):
            cluster_state = line.split("=", 1)[1]

        elif line.startswith("SLOTS_OK="):
            slots_ok = line.split("=", 1)[1]

        elif line.startswith("MASTER_COUNT="):
            master_count = int(line.split("=", 1)[1])

        elif line.startswith("REPLICA_COUNT="):
            replica_count = int(line.split("=", 1)[1])

        elif line.startswith("REPLICATION_UP="):
            replication_up = int(line.split("=", 1)[1])

    topology_pass = replica_count >= master_count
    replication_pass = replication_up == replica_count

    report = []

    report.append("=========================================")
    report.append("Redis Full Verification Report")
    report.append("=========================================")
    report.append("")

    report.append("1. Data Integrity")
    report.append(data_integrity)
    report.append("")

    report.append("2. Version Consistency")
    report.append(f"PASS - All nodes running Redis {version}")
    report.append("")

    report.append("3. Topology Health")
    report.append(f"PASS - {slots_ok}/{slots_ok} slots covered")

    if topology_pass:
        report.append("PASS - All masters have replicas")
    else:
        report.append("FAIL - Missing replica coverage")

    report.append("")

    report.append("4. Cluster State")
    report.append(f"PASS - cluster_state:{cluster_state}")
    report.append("")

    report.append("5. Replication Health")

    if replication_pass:
        report.append("PASS - All replicas master_link_status:up")
    else:
        report.append("FAIL - Replica link down")

    report.append("")
    report.append("=========================================")

    if (
        "PASS" in data_integrity
        and cluster_state == "ok"
        and topology_pass
        and replication_pass
    ):
        report.append("OVERALL RESULT: PASS")
    else:
        report.append("OVERALL RESULT: FAIL")

    report.append("=========================================")

    print()
    print("\n".join(report))

# --------------------------------------------------
# Scale Out (S1)
# --------------------------------------------------

def scale(add_nodes):

    if add_nodes != 2:
        print(
            f"{RED}Only --add-nodes 2 is supported "
            f"(adds one master + one replica).{NC}"
        )
        sys.exit(1)

    print(
        f"{YELLOW}Starting 2 new containers "
        f"(redis-node-7, redis-node-8)...{NC}"
    )

    log_action(
        "SCALE",
        "Bringing up overlay containers for scale-out."
    )

    infra_dir = os.path.join(BASE_DIR, "infra")

    if shutil.which("podman"):
        compose_cmd = [
            "podman-compose",
            "-f", "compose.yml",
            "-f", "compose.scale.yml",
            "up", "-d", "--build"
        ]
    else:
        compose_cmd = [
            "docker", "compose",
            "-f", "compose.yml",
            "-f", "compose.scale.yml",
            "up", "-d", "--build"
        ]

    result = subprocess.run(compose_cmd, cwd=infra_dir)

    if result.returncode != 0:
        print(f"{RED}Failed to start the new containers.{NC}")
        log_action("FAILED", "Scale-out container startup failed.")
        sys.exit(1)

    print(
        f"{YELLOW}Joining new master + replica "
        f"into the existing cluster...{NC}"
    )

    result = subprocess.run(
        ["ansible-playbook", "playbooks/scale_out.yml"],
        cwd=ANSIBLE_DIR
    )

    if result.returncode == 0:
        log_action(
            "SUCCESS",
            "Scale-out completed: new master/replica joined "
            "and slots rebalanced."
        )
    else:
        log_action(
            "FAILED",
            "Scale-out playbook failed while joining new nodes."
        )

# --------------------------------------------------
# CLI
# --------------------------------------------------

parser = argparse.ArgumentParser(
    description="Redis Cluster Tool"
)

subparsers = parser.add_subparsers(
    dest="command"
)

# Provision

p = subparsers.add_parser(
    "provision"
)

p.add_argument(
    "--version",
    default="7.0.15"
)

p.add_argument(
    "--masters",
    default=3,
    type=int
)

p.add_argument(
    "--replicas-per-master",
    default=1,
    type=int
)

# Data

data = subparsers.add_parser(
    "data"
)

data_sub = data.add_subparsers(
    dest="data_command"
)

seed = data_sub.add_parser(
    "seed"
)

seed.add_argument(
    "--keys",
    default=1000,
    type=int
)

data_sub.add_parser(
    "verify"
)

# Status

subparsers.add_parser(
    "status"
)

# Upgrade

u = subparsers.add_parser(
    "upgrade"
)

u.add_argument(
    "--target-version",
    required=True,
    help="Target Redis version"
)

u.add_argument(
    "--strategy",
    required=True,
    choices=["rolling"],
    help="Upgrade strategy"
)

# Verify

sub = subparsers.add_parser(
    "verify"
)

sub.add_argument(
     "--full",
     action="store_true"
)

# Scale

sc = subparsers.add_parser(
    "scale"
)

sc.add_argument(
    "--add-nodes",
    required=True,
    type=int,
    help="Number of nodes to add (only 2 is supported: 1 master + 1 replica)"
)

args = parser.parse_args()

check_prerequisites()

if args.command == "provision":

    provision(
        args.version,
        args.masters,
        args.replicas_per_master
    )

elif args.command == "status":

    status()

elif args.command == "upgrade":

    upgrade(
        args.target_version
    )

elif args.command == "verify":

    verify()

elif args.command == "scale":

    scale(
        args.add_nodes
    )

elif args.command == "data":

    if args.data_command == "seed":

        data_seed(
            args.keys
        )

    elif args.data_command == "verify":

        data_verify()

else:

    parser.print_help()
